# Server bind address
SWARNDB_HOST=0.0.0.0

# gRPC API port
SWARNDB_GRPC_PORT=50051

# REST API port
SWARNDB_REST_PORT=8080

# Data directory for collections, WAL, and indexes
SWARNDB_DATA_DIR=./data

# Log level: trace, debug, info, warn, error
SWARNDB_LOG_LEVEL=info

# Comma-separated API keys for authentication (empty = no auth)
SWARNDB_API_KEYS=

# Maximum concurrent client connections
SWARNDB_MAX_CONNECTIONS=1000

# Request timeout in milliseconds
SWARNDB_REQUEST_TIMEOUT_MS=30000
