# SwarnDB Environment Configuration
# Copy this file to .env and adjust as needed:
#   cp .env.example .env

# ---- Network ----

# Host address the server binds to (use 0.0.0.0 for production)
SWARNDB_HOST=0.0.0.0

# gRPC API port
SWARNDB_GRPC_PORT=50051

# Max gRPC message size in bytes (default: 64MB)
SWARNDB_MAX_MESSAGE_SIZE=67108864

# Max REST request body size in bytes (default: 256MB)
SWARNDB_MAX_REQUEST_BODY_BYTES=268435456

# REST API port
SWARNDB_REST_PORT=8080

# Allowed CORS origins (comma-separated, empty = allow all)
SWARNDB_CORS_ORIGINS=

# ---- Storage ----

# Directory for persistent data (indexes, WAL, collections)
SWARNDB_DATA_DIR=/data

# WAL maximum size in bytes before rotation (default: 256MB)
SWARNDB_WAL_MAX_SIZE=268435456

# Maximum number of vectors in the hot (RAM) tier for tiered storage (default: 100000)
SWARNDB_TIERED_HOT_CAPACITY=100000

# ---- Logging ----

# Log level: trace, debug, info, warn, error
SWARNDB_LOG_LEVEL=info

# ---- Authentication ----

# Comma-separated list of API keys (leave empty to disable auth)
SWARNDB_API_KEYS=

# ---- TLS ----

# Path to TLS certificate file (PEM). Both cert and key required to enable TLS.
# SWARNDB_TLS_CERT_PATH=/etc/swarndb/tls/tls.crt

# Path to TLS private key file (PEM).
# SWARNDB_TLS_KEY_PATH=/etc/swarndb/tls/tls.key

# ---- Connection Limits ----

# Maximum number of concurrent connections
SWARNDB_MAX_CONNECTIONS=1000

# ---- Concurrency Control ----

# Maximum number of concurrent search requests (default: 500)
SWARNDB_MAX_CONCURRENT_SEARCHES=500

# Minimum concurrency limit for adaptive sizing
SWARNDB_MIN_CONCURRENCY=10

# Maximum concurrency limit for adaptive sizing
SWARNDB_MAX_CONCURRENCY=200

# Target p99 latency in ms for adaptive concurrency control
SWARNDB_TARGET_P99_LATENCY_MS=500

# ---- Adaptive Concurrency ----

# EMA smoothing factor for latency tracking (0.0-1.0, lower = smoother)
SWARNDB_CONCURRENCY_EMA_ALPHA=0.1

# Latency multiplier that triggers concurrency decrease (e.g. 1.2 = 120% of target)
SWARNDB_CONCURRENCY_HIGH_THRESHOLD=1.2

# Latency multiplier that triggers concurrency increase (e.g. 0.5 = 50% of target)
SWARNDB_CONCURRENCY_LOW_THRESHOLD=0.5

# Rate to decrease concurrency when latency is high (0.0-1.0)
SWARNDB_CONCURRENCY_DECREASE_RATE=0.10

# Rate to increase concurrency when latency is low (0.0-1.0)
SWARNDB_CONCURRENCY_INCREASE_RATE=0.05

# Maximum queued requests when at concurrency capacity
SWARNDB_SEARCH_QUEUE_SIZE=1000

# ---- Timeouts ----

# General request timeout in milliseconds
SWARNDB_REQUEST_TIMEOUT_MS=30000

# Search query timeout in milliseconds
SWARNDB_SEARCH_TIMEOUT_MS=5000

# Bulk insert timeout in milliseconds
SWARNDB_BULK_TIMEOUT_MS=300000

# Compute-intensive operation timeout in seconds (graph compute, optimize, etc.)
SWARNDB_COMPUTE_TIMEOUT_SECS=30

# ---- Validation Limits ----

# Maximum metadata size per vector in bytes (default: 4MB)
SWARNDB_MAX_METADATA_SIZE_BYTES=4194304

# Maximum allowed vector dimension
SWARNDB_MAX_VECTOR_DIMENSION=65536

# Maximum number of vectors in a single request
SWARNDB_MAX_VECTORS_PER_REQUEST=10000

# Maximum length of a collection name
SWARNDB_MAX_COLLECTION_NAME_LENGTH=256

# ---- Search Limits ----

# Maximum allowed k value for search queries
SWARNDB_MAX_K=10000

# Maximum ef_search value allowed per query (higher = more accurate, slower)
SWARNDB_MAX_EF_SEARCH=10000

# ---- HNSW Index Tuning ----

# Maximum effective search width cap (prevents excessive computation from large k values)
SWARNDB_MAX_EF=100000

# Maximum ef_construction override for bulk insert (higher = better index quality, slower build)
SWARNDB_MAX_EF_CONSTRUCTION=2000

# ---- Bulk Insert Limits ----

# Maximum number of vectors locked during batch operations
SWARNDB_MAX_BATCH_LOCK_SIZE=10000

# WAL flush interval limit for bulk insert operations
SWARNDB_MAX_WAL_FLUSH_INTERVAL=100000

# Maximum number of messages in a single gRPC bulk_insert stream
SWARNDB_MAX_BULK_INSERT_MESSAGES=100000

# Maximum total payload bytes in a single gRPC bulk_insert stream (512 MB)
SWARNDB_MAX_BULK_INSERT_PAYLOAD_BYTES=536870912

# ---- Storage Tuning ----

# Number of vectors in the memtable before flushing to a segment (default: 50000)
SWARNDB_MEMTABLE_FLUSH_THRESHOLD=50000

# ---- JSON Config File (optional) ----

# Path to a JSON config file (overridden by env vars above)
# SWARNDB_CONFIG=swarndb.json
